import { Palette, Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

// import "../assets/fonts/Chillax_Variable/Fonts/OTF/Chillax-Medium.otf";
import "../assets/fonts/Plus_Jakarta_Sans/static/PlusJakartaSans-Medium.ttf";

export enum Page { SelectionPage, TimerPage, TimerFinished }
export enum StopType { TimerFinished, UserStopped }

export struct TimeOption {
    time: string,
    minutes: string,
}

component SelectionButton inherits VerticalBox {
    in property <string> time;
    in property <string> minutes;
    in property <length> font-size;

    callback clicked <=> touch.clicked;

    Text {
	font-size: root.font-size/2;
	text: "Minutes: " + minutes;
    }

    Rectangle {
	touch := TouchArea {}

	background: touch.has-hover ? #A169C7 : #C682F5;
	border-radius: 4px;

	txt := Text {
	    text: root.time;
	    font-size: root.font-size;
	    color: black;
	}

    }
}

export component MainWindow inherits Window {
    title: "Schisaciaccole";
    icon: @image-url("../assets/icon_256.png");
    preferred-width: 526px; 
    preferred-height: 326px;
    default-font-family: "Plus Jakarta Sans";
    // default-font-family: "Chillax";
    forward-focus: scope;

    property <bool> on-top: false;

    always-on-top: on-top;

    property <float> ui-scale: Math.min(root.width / 526px, root.height / 326px);

    in-out property <duration> timer-time: 3s;
    in-out property <bool>     running-state: false;
    in-out property <Page>     page: SelectionPage; 
    in property     <bool>     is_fullscreen: false;
    in property     <[TimeOption]> options;
    in property     <bool>     is-macos;

    callback start-pause();
    callback stop(StopType);
    callback select-time(int);
    callback compute-options();
    callback play-sound();
    callback set-selection-page();
    callback quit();
    callback fullscreen(bool);
    callback help();

    if is-macos: MenuBar {
	Menu {
	    title: @tr("Window");
	    MenuItem {
		title: @tr("Always on top");
		activated => { on-top = !on-top; }
		shortcut: @keys(Control + T);
	    }
	}
    }

    scope := FocusScope {
        KeyBinding {
            keys: @keys(Q);
            activated => { quit(); }
        }

        KeyBinding {
            keys: @keys(M);
            activated => { fullscreen(false); }
        }

        KeyBinding {
            keys: @keys(Escape);
            activated => { fullscreen(true); }
        }

        KeyBinding {
            keys: @keys(T);
            activated => { on-top = !on-top; }
        }

        KeyBinding {
            keys: @keys(H);
            activated => { help(); }
        }
    }

    timer := Timer {
	interval  : 1s;
	running: running-state;
	
	triggered() => {
	    if (running-state) {
		timer-time -= 1s;
		if (timer-time <= 0) {
		    stop(StopType.TimerFinished);
		    play-sound();
		}
	    } 
	}
    }

    compute-options-timer := Timer {
	interval  : 3s;
	running: !running-state;
	
	triggered() => {
	    // when the main timer is stopped keep updating the selection
	    compute-options();
	}
    }

    property <int> hours  : Math.floor(timer-time / 60s / 60);
    property <int> minutes: Math.floor(Math.mod(timer-time / 60s, 60));
    property <int> seconds: Math.mod(timer-time / 1s, 60);
    property <string> displayTimer: 
        (hours >= 1 ? "0" + hours + ":" : "") +
        (minutes < 10 ? "0" : "") + minutes + ":" +
        (seconds < 10 ? "0" : "") + seconds;

    // property <string> displayHour: 
    //     hours >= 1 ? "0" + hours : "";
    // property <string> displayMinute: 
    //     (minutes < 10 ? "0" : "") + minutes;
    // property <string> displaySeconds: 
    //     (seconds < 10 ? "0" : "") + seconds;

    if on-top : Rectangle {
        width: 10px;
        height: 10px;
        x: root.width - self.width - 2px; // Aligns to the right
        y: 2px; // Aligns to the top
        background: #C682F5;
        border-radius: self.width / 2; // Makes the rectangle a circle
    }



    // render this if page is SelectionPage
    if page == Page.SelectionPage : VerticalBox {
	alignment: center;
	padding: 25px * ui-scale;


	Text {
	    text: "Quando deve finire questa cerimonia?";
	    font-size: 22px * root.ui-scale;
	    horizontal-alignment: start;
	}

	GridLayout {
	    spacing: 15px * ui-scale;

	    for option[index] in root.options: SelectionButton {
		row: Math.floor(index / 4);
		col: Math.mod(index, 4);

		font-size: 18px * root.ui-scale;
		time: option.time;
		minutes: option.minutes;
		clicked => { select-time(index); }
	    }
	}
    }

    // render this if page is TimerPage
    if page == Page.TimerPage : VerticalBox {
	alignment: center;
	padding: 25px * ui-scale;


	Text {
	    text: displayTimer;
	    color: #C682F5;
	    font-size: 100px * root.ui-scale;
	    horizontal-alignment: center;
	}

	HorizontalBox {
	    alignment: center;

	    // Button {
	    // 	text: running-state ? "Pause" : "Start";
	    // 	clicked => { start-pause(); }
	    // }

	    Button {
		text: "Stop";
		clicked => { stop(StopType.UserStopped); }
	    }
	}
    }

    
    if page == Page.TimerFinished : VerticalBox {
	alignment: center;
	padding: 25px * ui-scale;


	Text {
	    text: "Congrats!\nScrum ceremony finished";
	    color: #C682F5;
	    font-size: 36px * root.ui-scale;
	    horizontal-alignment: center;
	}

	Text {
	    text: "Now get the fuck outta here";
	    color: #ffffff;
	    font-size: 24px * root.ui-scale;
	    horizontal-alignment: center;
	}


	HorizontalBox {
	    alignment: center;

	    Button {
		text: "Selection page";
		clicked => { set-selection-page(); }
	    }
	}
    }
    
}


export component Help inherits Window {
    title: "Schisaciaccole";
    preferred-width: 526px; 
    preferred-height: 226px;
    always-on-top: true;

    // Wrap in a conditional so the window does not statically adopt this
    // layout's font-driven size as its own (which loops: size -> ui-scale ->
    // font-size -> size). Same pattern as MainWindow's `if page == ...` bodies.
    VerticalBox {
	width: root.width;
	height: root.height;
	alignment: center;

	Text {
	    text: "Keybindings:";
	    color: white;
	    font-size: 24px;
	    horizontal-alignment: center;
	}


	HorizontalLayout {
	    alignment: center;
	    GridLayout {
		spacing-horizontal: 50px;
		Row {
		    Text {
			// text: "You can't start a timer with 0 seconds";
			text: "Q";
			font-size: 15pt;
			horizontal-alignment: left;
		    }

		    Text {
			// text: "You can't start a timer with 0 seconds";
			text: "Quit";
			font-size: 15pt;
			horizontal-alignment: left;
		    }
		}
		Row {
		    Text {
			// text: "You can't start a timer with 0 seconds";
			text: "M";
			font-size: 15pt;
			horizontal-alignment: left;
		    }

		    Text {
			// text: "You can't start a timer with 0 seconds";
			text: "Toggle fullscreen";
			font-size: 15pt;
			horizontal-alignment: left;
		    }
		}
		Row {
		    Text {
			// text: "You can't start a timer with 0 seconds";
			text: "Esc";
			font-size: 15pt;
			horizontal-alignment: left;
		    }

		    Text {
			// text: "You can't start a timer with 0 seconds";
			text: "Exit fullscreen";
			font-size: 15pt;
			horizontal-alignment: left;
		    }
		}
		Row {
		    Text {
			// text: "You can't start a timer with 0 seconds";
			text: "T";
			font-size: 15pt;
			horizontal-alignment: left;
		    }

		    Text {
			// text: "You can't start a timer with 0 seconds";
			text: "Toggle always-on-top, showed by small circle in top right corner";
			font-size: 15pt;
			horizontal-alignment: left;
		    }
		}
	    }
	}
    }
}
